# ─────────────────────────────────────────────────────────────────────────────
# chezz backend — environment
# Copy to `.env` and fill in. Never commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# Postgres connection string (postgres.js).
# Local docker-compose default shown; in prod point at your managed/compose DB.
DATABASE_URL=postgres://chezz:chezz@localhost:5432/chezz

# BetterAuth — REQUIRED.
# A long random secret used to sign sessions/tokens. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
# The public origin BetterAuth is served from (used for cookies/redirects).
# Local: http://localhost:3000   Prod: https://api.chezz.app
BETTER_AUTH_URL=http://localhost:3000

# Public base URL of this API (used for CORS / trusted origins).
# Usually the same as BETTER_AUTH_URL.
APP_BASE_URL=http://localhost:3000

# Server port.
PORT=3000

# Contacts matching — REQUIRED for /contacts/match and /me/discovery-phone.
# HMAC-SHA256 key used to hash phone numbers (E.164) into user.phoneHash.
# Generate with: openssl rand -base64 32  — and NEVER rotate without re-hashing.
CONTACT_HASH_SECRET=change-me-to-a-long-random-string

# ── Resend (email one-time codes) ────────────────────────────────────────────
# If RESEND_API_KEY is missing, the server runs in DEV OTP MODE: email codes are
# logged to the console ([dev-otp] email code for ...) instead of being mailed.
# Set this in prod. EMAIL_FROM must be a verified Resend sender/domain.
RESEND_API_KEY=
EMAIL_FROM=chezz <login@chezz.app>

# ── Sign in with Apple (native) ──────────────────────────────────────────────
# APPLE_CLIENT_ID is the *Services ID* (e.g. digital.mazz.chezz.signin).
APPLE_CLIENT_ID=
# The native app's bundle id — MANDATORY for native sign-in (aud claim). Keep as digital.mazz.chezz.
APPLE_APP_BUNDLE_ID=digital.mazz.chezz
# From the Apple Developer portal:
APPLE_TEAM_ID=
APPLE_KEY_ID=
# The contents of the AuthKey_XXXX.p8 file. Either paste with literal \n escapes
# OR the full PEM with real newlines. Both are accepted.
APPLE_PRIVATE_KEY=

# ── Push notifications (APNs, token-based .p8 auth) ──────────────────────────
# If these are blank, push is DISABLED (notifications become no-ops). The APNs key
# is a SEPARATE key from the Sign-in-with-Apple key (Keys, new key, enable APNs).
# APNS_TEAM_ID defaults to APPLE_TEAM_ID (same Apple Developer team); the APNs topic
# is the app bundle id (APPLE_APP_BUNDLE_ID). One key serves sandbox + production.
APNS_KEY_ID=
APNS_TEAM_ID=
# Contents of the AuthKey_XXXX.p8 (literal \n escapes OR real newlines, both accepted).
APNS_PRIVATE_KEY=
