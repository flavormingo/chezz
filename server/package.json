{
  "name": "chezz-server",
  "version": "1.0.0",
  "description": "Backend for chezz — friends, online play, accounts (Hono + BetterAuth + Postgres).",
  "type": "module",
  "license": "GPL-3.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "better-auth": "^1.6.20",
    "chess.js": "^1.4.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.26",
    "libphonenumber-js": "^1.13.7",
    "postgres": "^3.4.9",
    "resend": "^4.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0"
  }
}
